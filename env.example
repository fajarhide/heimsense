# Environment Variables
# Choose your provider (uncomment one):
# ANTHROPIC_BASE_URL=https://api.openai.com/v1           # OpenAI
# ANTHROPIC_BASE_URL=https://api.deepseek.com/v1         # DeepSeek
# ANTHROPIC_BASE_URL=https://api.groq.com/openai/v1      # Groq
# ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1        # OpenRouter
# ANTHROPIC_BASE_URL=http://localhost:11434/v1           # Ollama (local)
ANTHROPIC_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=your-api-key-here
DEFAULT_MODEL=gpt-4o-mini
FORCE_MODEL=
LISTEN_ADDR=:8080
REQUEST_TIMEOUT_MS=120000
MAX_RETRIES=3
