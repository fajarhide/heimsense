# Environment Variables
# Choose your provider (uncomment one):
# ANTHROPIC_BASE_URL=https://api.openai.com/v1           # OpenAI
# ANTHROPIC_BASE_URL=https://api.deepseek.com/v1         # DeepSeek
# ANTHROPIC_BASE_URL=https://api.groq.com/openai/v1      # Groq
# ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1        # OpenRouter
# ANTHROPIC_BASE_URL=http://localhost:11434/v1           # Ollama (local)
ANTHROPIC_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_CUSTOM_MODEL_OPTION=gpt-4o-mini
ANTHROPIC_CUSTOM_MODEL_OPTION_NAME=Heimsense Model
ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION=Custom model via Heimsense adapter
ANTHROPIC_CUSTOM_FORCE_MODEL=

# (Optional) Map Claude Code's hardcoded background models to your provider's cheaper models
# If left empty, these will automatically fallback to your ANTHROPIC_CUSTOM_MODEL_OPTION above.
# MODEL_MAP_HAIKU=gemini-2.5-flash
# MODEL_MAP_SONNET=gemini-2.5-pro
# MODEL_MAP_OPUS=gemini-2.5-pro

LISTEN_ADDR=:8080
REQUEST_TIMEOUT_MS=120000
MAX_RETRIES=3
